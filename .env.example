# Copy to .env and adjust. Never commit the real .env.

DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=*

# Database (Django reads this). Inside Docker the host is the `db` service.
DATABASE_URL=postgres://myvilla:myvilla@db:5432/myvilla

# Postgres container credentials (used by docker-compose)
POSTGRES_DB=myvilla
POSTGRES_USER=myvilla
POSTGRES_PASSWORD=myvilla

# Comma-separated origins allowed to call the API (the Next.js frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT token lifetimes (minutes / days)
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# --------------------------------------------------------------------------- #
# Frontend base URL — used to build the password-reset link in emails.
# Production: set to your deployed frontend, e.g. https://myvilla.com
# --------------------------------------------------------------------------- #
FRONTEND_URL=http://localhost:3000

# --------------------------------------------------------------------------- #
# Email / SMTP (2-in-1)
#   LOCAL DEV : leave EMAIL_HOST EMPTY → Django prints the email (with the
#               reset link) to the container logs. No SMTP server needed.
#   PRODUCTION: set EMAIL_HOST + credentials → real emails go out over SMTP.
# Example (Gmail App Password): EMAIL_HOST=smtp.gmail.com, PORT=587, TLS=True
# Example (SendGrid): EMAIL_HOST=smtp.sendgrid.net, USER=apikey, PASSWORD=<key>
# --------------------------------------------------------------------------- #
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=MyVilla <no-reply@myvilla.com>
# How long a reset link stays valid (seconds). 900 = 15 minutes.
PASSWORD_RESET_TIMEOUT=900

# --------------------------------------------------------------------------- #
# Media / image storage (2-in-1)
#   LOCAL DEV : leave CLOUDINARY_URL EMPTY → villa images are saved to
#               backend/media/ on disk and served by Django at /media/.
#   PRODUCTION: set CLOUDINARY_URL → images are uploaded to Cloudinary and
#               served from its CDN. No other change needed.
#   Get it from your Cloudinary dashboard ("API Environment variable"):
#   CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# --------------------------------------------------------------------------- #
CLOUDINARY_URL=

# --------------------------------------------------------------------------- #
# Security / rate limiting (optional overrides — defaults are sane)
#   REDIS_URL: in production, point all workers at one Redis so rate-limit
#   counters and IP bans are shared (dependency-free Django RedisCache).
# --------------------------------------------------------------------------- #
# REDIS_URL=redis://redis:6379/0
# RL_GENERAL_LIMIT=120
# RL_GENERAL_WINDOW=60
# RL_AUTH_LIMIT=12
# RL_AUTH_WINDOW=300
# RL_BLOCK_SECONDS=900
# TLS hardening — enable these once the site is served over HTTPS in prod:
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# --- Google Sign-In ---------------------------------------------------------
# The OAuth 2.0 *Web application* client id from Google Cloud Console
# (APIs & Services -> Credentials). MUST be identical to the frontend's
# NEXT_PUBLIC_GOOGLE_CLIENT_ID: every Google token is checked against it.
# Leave empty to switch the "Continue with Google" button off.
GOOGLE_CLIENT_ID=

# --- WhatsApp booking greeting (Meta Cloud API) -----------------------------
# Sends the guest their booking details + the villa's photo the moment they
# pay. Leave WHATSAPP_TOKEN empty to keep it off: the message is written to the
# logs instead, so you can see it in dev without any Meta account.
# See properties/whatsapp.py for the exact template to submit to Meta
# (category: Utility, header: Image, six body variables).
WHATSAPP_TOKEN=
# The sending number's ID from the WhatsApp Manager — NOT the number itself.
WHATSAPP_PHONE_NUMBER_ID=
# Approved template name. Empty = plain text, which WhatsApp only delivers in
# the 24h window after the user messaged first (testing only).
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en
# true if the template ends in a dynamic URL button (it receives "villa/<id>").
WHATSAPP_TEMPLATE_URL_BUTTON=
# Country code (digits only, e.g. 91) for numbers saved without one.
WHATSAPP_DEFAULT_DIAL_CODE=
WHATSAPP_API_VERSION=v21.0
